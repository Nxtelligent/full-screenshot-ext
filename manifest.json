{
  "manifest_version": 3,
  "name": "Full Page Screenshot to Clipboard",
  "version": "1.0.0",
  "description": "One-click full page screenshot, copied to clipboard instantly. Paste into Claude, ChatGPT, Gemini, or any app.",
  "permissions": [
    "activeTab",
    "scripting",
    "offscreen",
    "clipboardWrite"
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Capture full page screenshot"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
